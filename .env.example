# API local
APP_PORT=8020
REVIEW_NOTES_DIR=/app/review_runs

# GitHub App
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=troque-por-um-secret-forte
GITHUB_API_BASE_URL=https://api.github.com

# Recomendado para Docker Compose: baixe a private key do GitHub App e salve em
# ./secrets/github-app-private-key.pem.
GITHUB_APP_PRIVATE_KEY_HOST_PATH=./secrets/github-app-private-key.pem
GITHUB_APP_PRIVATE_KEY_FILE=/run/secrets/github-app-private-key.pem

# Alternativa sem Docker: use GITHUB_APP_PRIVATE_KEY com \n escapado.
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# LLM / Kimi 2.6 via Telnyx
LLM_API_BASE_URL=https://api.telnyx.com/v2/ai
LLM_MODEL=moonshotai/Kimi-K2.6
LLM_API_KEY=
AGENT_MAX_TURNS=12
